# ============================================================
# AI Employee — Environment Configuration
# Gold Tier — Panaversity AI Employee Hackathon 2026
# Copy to .env and fill in your values
# ============================================================

# ── Core ─────────────────────────────────────────────────────
DRY_RUN=true
VAULT_PATH=./vault
LOG_LEVEL=INFO
MAX_ACTIONS_PER_HOUR=10
PAYMENT_AUTO_APPROVE_LIMIT=50

# ── Claude AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail OAuth2 ─────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback
GMAIL_TOKEN_PATH=./sessions/gmail_token.json
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
GMAIL_POLL_INTERVAL=60

# ── LinkedIn ─────────────────────────────────────────────────
# OAuth 2.0 — 3-legged flow
# Setup: python -m setup.oauth_setup  → choose LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRY=          # Unix timestamp — auto-updated on token refresh
LINKEDIN_PERSON_URN=            # urn:li:person:XXXXX — auto-set on first auth
LINKEDIN_POLL_INTERVAL=300

# ── Twitter / X ──────────────────────────────────────────────
# OAuth 1.0a (posting) + Bearer Token (reading)
# Setup: python -m setup.oauth_setup  → choose Twitter
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_MY_USER_ID=             # Auto-set on first auth (numeric ID)
TWITTER_POLL_INTERVAL=120

# ── Facebook ─────────────────────────────────────────────────
# Graph API v19.0 — Page Access Token
# Setup: python -m setup.oauth_setup  → choose Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=     # Short-lived token (exchanged automatically)
FACEBOOK_LONG_LIVED_TOKEN=      # 60-day token — auto-refreshed by watcher
FACEBOOK_PAGE_ID=
FACEBOOK_POLL_INTERVAL=300

# ── Instagram ────────────────────────────────────────────────
# Graph API v19.0 — Business/Creator account required
# Linked via Facebook — same long-lived token
INSTAGRAM_ACCESS_TOKEN=         # Same as FACEBOOK_LONG_LIVED_TOKEN
INSTAGRAM_ACCOUNT_ID=           # IG Business Account numeric ID
INSTAGRAM_POLL_INTERVAL=300

# ── WhatsApp (Playwright) ────────────────────────────────────
WHATSAPP_SESSION_PATH=./sessions/whatsapp
WHATSAPP_HEADLESS=true
WHATSAPP_POLL_INTERVAL=30

# ── Bank Monitor ─────────────────────────────────────────────
BANK_CSV_WATCH_FOLDER=./uploads/bank
BANK_CURRENCY=PKR
BANK_ANOMALY_THRESHOLD=50000

# ── API Server ───────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# ── Notifications ────────────────────────────────────────────
ALERT_EMAIL=admin@example.com
