# ============================================================
# AI Employee — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Core ---
DRY_RUN=true
VAULT_PATH=./vault
LOG_LEVEL=INFO
MAX_ACTIONS_PER_HOUR=10
PAYMENT_AUTO_APPROVE_LIMIT=50

# --- Claude AI ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Gmail OAuth2 ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback
GMAIL_TOKEN_PATH=./sessions/gmail_token.json

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=

# --- Twitter / X ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# --- Facebook / Instagram ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- WhatsApp (Playwright) ---
WHATSAPP_SESSION_PATH=./sessions/whatsapp
WHATSAPP_HEADLESS=true

# --- Bank Monitor ---
BANK_CSV_WATCH_FOLDER=./uploads/bank
BANK_CURRENCY=PKR

# --- API Server ---
API_HOST=127.0.0.1
API_PORT=8000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# --- Notifications ---
ALERT_EMAIL=admin@example.com
