# ─────────────────────────────────────────────────────────
# AI Employee — Root .env for docker-compose
# Copy to .env and fill in your values before running
# docker-compose up -d
# ─────────────────────────────────────────────────────────

# Core
DRY_RUN=true
LOG_LEVEL=INFO
BANK_CURRENCY=PKR
MAX_ACTIONS_PER_HOUR=10

# Claude AI (required)
ANTHROPIC_API_KEY=sk-ant-...

# Gmail OAuth2
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=

# Facebook / Instagram
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
